rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Anyone can read/write team votes (identified by userId in doc ID)
    match /teamVotes/{voteId} {
      allow read: if true;
      allow write: if true;
    }
    // Boss votes readable by all, writable by all (PIN enforced in app)
    match /bossVotes/{date} {
      allow read: if true;
      allow write: if true;
    }
  }
}
